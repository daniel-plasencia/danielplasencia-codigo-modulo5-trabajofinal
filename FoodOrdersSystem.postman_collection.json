				{
					"name": "PASO 1 - Login (obtener JWT)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('token', jsonData.token);",
									"",
									"pm.test('Login exitoso', function () {",
									"    pm.response.to.have.status(200);",
									"    pm.expect(jsonData.token).to.not.be.empty;",
									"});",
									"",
									"pm.test('Token contiene roles', function () {",
									"    pm.expect(jsonData.roles).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"juan.perez@example.com\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl_user}}/api/auth/login",
							"host": ["{{baseUrl_user}}"],
							"path": ["api", "auth", "login"]
